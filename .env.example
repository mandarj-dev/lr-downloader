# S3 base URL - the app will fetch <BASE_S3_URL><LR_NO><POD_SUFFIX>.<extension>
BASE_S3_URL=https://courier-weight-images.s3.ap-south-1.amazonaws.com/tracking_pod_image/

# Suffix appended after the LR number in the S3 object key (e.g. LR1001_pod.pdf)
POD_SUFFIX=_pod

# Extensions to try, in order, for each LR number
EXTENSIONS=pdf,jpg,jpeg,png

# HTTP request timeout (seconds) per file attempt
REQUEST_TIMEOUT_SECONDS=20

# How many LR downloads to run in parallel
MAX_CONCURRENT_DOWNLOADS=5
